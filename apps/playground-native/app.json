{
  "expo": {
    "name": "JAW Demo Native",
    "slug": "jaw-demo-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "id.jaw.demo.native",
      "developmentTeam": "9234ZPYS2R",
      "_comment_associatedDomains": [
        "Associated Domains enable passkey authentication with your domain.",
        "",
        "DEVELOPMENT (ngrok): Use your ngrok URL",
        "  Example: webcredentials:abc123.ngrok-free.app",
        "",
        "PRODUCTION: Use your deployed keys.jaw.id domain",
        "  Example: webcredentials:keys.jaw.id",
        "",
        "Requirements:",
        "  - Must match EXPO_PUBLIC_RP_ID in .env",
        "  - Requires AASA file at https://[domain]/.well-known/apple-app-site-association",
        "  - AASA must include: TEAM_ID.bundleIdentifier (e.g., 9234ZPYS2R.id.jaw.demo.native)"
      ],
      "associatedDomains": [
        "webcredentials:932a-185-206-200-227.ngrok-free.app"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.jaw.demo"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "_comment_scheme": [
      "Custom URL scheme for deep linking from browser back to app.",
      "Used as callback URL pattern: {scheme}://auth",
      "Example: jaw-demo://auth",
      "",
      "This enables the cross-platform authentication flow:",
      "  1. App opens Safari/Chrome for passkey authentication",
      "  2. User completes authentication in browser",
      "  3. Browser redirects to {scheme}://auth with credentials",
      "  4. App receives credentials and completes connection"
    ],
    "scheme": "jaw-demo",
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ]
  }
}

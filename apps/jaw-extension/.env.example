# JAW Extension build environment variables.
#
# Copy this file to .env.local (gitignored) and fill in real values, OR set
# these in your shell / CI secret store. Vite reads process.env at build time
# via `apps/jaw-extension/vite.config.ts` and bakes the values into the bundle
# as compile-time constants. The chosen values for the build are immutable in
# the resulting extension package — no runtime reconfiguration of these.

# JAW API key. Required for the SDK to talk to JAW's relay.
#   - For dev (local testing): use a development key. Build with `--mode development`
#     and the CI guard is skipped so an empty value also compiles (the runtime
#     SDK will reject RPCs but the bundle builds).
#   - For staging: use a staging key tied to keys-staging.jaw.id (whichever
#     environment your backend exposes).
#   - For production (Chrome Web Store builds): use the production key. CI
#     enforces this hard via `process.env.CI === 'true'` in vite.config.ts.
JAW_EXTENSION_API_KEY=

# Override the keys.jaw.id URL. Defaults to https://keys.jaw.id when unset.
#   - Production: leave unset.
#   - Staging: e.g. https://keys-staging.jaw.id
#   - Local dev: http://localhost:3001 (matches `apps/keys-jaw-id`'s dev server)
# Used for content-script allowlist (host_permissions + content_scripts.matches)
# AND for the SDK's preference.keysUrl at JAW.create() time.
JAW_KEYS_URL=

# Build mode signal. Set automatically by Vite from the --mode flag. Listed
# here just for reference — you generally won't set this manually.
#   import.meta.env.MODE === 'development' enables: showTestnets default,
#     watch mode, sourcemaps inline, less aggressive minification.
#   import.meta.env.MODE === 'production' enables: mainnet-only default,
#     hidden sourcemaps, terser.
# NODE_ENV=

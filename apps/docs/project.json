{
  "name": "docs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/docs/docs",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "commands": ["vocs build", "tsx scripts/generate-llms.ts"],
        "cwd": "apps/docs",
        "parallel": false
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vocs dev",
        "cwd": "apps/docs"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vocs preview",
        "cwd": "apps/docs"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}

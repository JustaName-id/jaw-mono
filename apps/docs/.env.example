# JAW API Key for fetching capabilities
# Create a key restricted to docs.jaw.id domain at https://dashboard.jaw.id/
VITE_JAW_API_KEY=your-api-key-here

# PostHog analytics
# Set to `true` only in the deployed environment.
VITE_ANALYTICS_ENABLED=false
# Project API key for the docs PostHog project.
VITE_POSTHOG_KEY=your-posthog-project-key
# Reverse-proxy path (see vercel.json rewrites). Keep as `/analytics`.
VITE_POSTHOG_HOST=/analytics
# JAW API key (create one at https://dashboard.jaw.id/)
NEXT_PUBLIC_API_KEY=your-api-key-here
# ENS domain used to issue subnames (optional)
NEXT_PUBLIC_ENS_NAME=your-ens.eth
# keys.jaw.id URL (defaults to production when unset)
NEXT_PUBLIC_KEYS_URL=http://localhost:3000

# PostHog analytics
# Set to `true` only in the deployed environment.
NEXT_PUBLIC_ANALYTICS_ENABLED=false
# Project API key for the playground PostHog project.
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-project-key
# Reverse-proxy path (see next.config.js rewrites). Keep as `/analytics`.
NEXT_PUBLIC_POSTHOG_HOST=/analytics

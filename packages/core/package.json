{
  "name": "@jaw.id/core",
  "description": "Core SDK - EIP-1193 provider, smart account operations, passkey management",
  "version": "0.3.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@jaw-mono/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JustaName-id/jaw-mono.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "generate-sdk-info": "bunx tsx scripts/generate-sdk-info.ts"
  },
  "nx": {
    "targets": {
      "build": {
        "dependsOn": [
          "generate-sdk-info"
        ],
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "commands": [
            "tsc --build tsconfig.lib.json",
            "bunx tsup"
          ],
          "parallel": false
        },
        "cache": true,
        "inputs": [
          "production",
          "^production"
        ],
        "outputs": [
          "{projectRoot}/dist"
        ]
      },
      "typecheck": {
        "dependsOn": [
          "generate-sdk-info"
        ]
      },
      "test": {
        "cache": true,
        "inputs": [
          "default",
          "^production",
          "{projectRoot}/vitest.config.ts"
        ],
        "outputs": [
          "{workspaceRoot}/coverage/{projectRoot}"
        ],
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "command": "bunx vitest run"
        }
      }
    }
  },
  "dependencies": {
    "axios": "1.13.5",
    "eventemitter3": "5.0.1",
    "mipd": "^0.0.7",
    "ox": "0.9.6",
    "qs": "6.14.1",
    "tslib": "2.8.1",
    "viem": "^2.38.2",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/qs": "^6.14.0",
    "vitest": "^3.0.0"
  }
}

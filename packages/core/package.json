{
  "name": "@jaw.id/core",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@jaw-mono/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "generate-sdk-info": "npx tsx scripts/generate-sdk-info.ts"
  },
  "nx": {
    "targets": {
      "build": {
        "dependsOn": ["generate-sdk-info"]
      },
      "test": {
        "cache": true,
        "inputs": [
          "default",
          "^production",
          "{projectRoot}/vitest.config.ts"
        ],
        "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
        "executor": "nx:run-commands",
        "options": {
          "cwd": "{projectRoot}",
          "command": "npx vitest run"
        }
      }
    }
  },
  "dependencies": {
    "eventemitter3": "5.0.1",
    "ox": "0.9.6",
    "viem": "^2.38.2",
    "tslib": "^2.3.0",
    "zustand": "^5.0.8",
    "vitest": "^3.0.0"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  }
}

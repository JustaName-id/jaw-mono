          "env": "JAW_CHAIN_ID",
          "name": "chain",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "api-key": {
          "description": "JAW API key",
          "env": "JAW_API_KEY",
          "name": "api-key",
          "hasDynamicHelp": false,
          "multiple": false,
          "type": "option"
        },
        "yes": {
          "char": "y",
          "description": "Skip confirmations (for AI agents)",
          "name": "yes",
          "allowNo": false,
          "type": "boolean"
        },
        "quiet": {
          "char": "q",
          "description": "Suppress non-essential output",
          "name": "quiet",
          "allowNo": false,
          "type": "boolean"
        }
      },

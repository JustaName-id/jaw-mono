      "aliases": [],
      "args": {},
      "description": "Initialize JAW CLI configuration",
      "examples": [
        "<%= config.bin %> config init",
        "<%= config.bin %> config init --api-key your-key --chain 8453"
      ],
      "flags": {
        "output": {
          "char": "o",
          "description": "Output format",
          "env": "JAW_OUTPUT",
          "name": "output",
          "default": "human",
          "hasDynamicHelp": false,
          "multiple": false,
          "options": [
            "json",
            "human"
          ],
          "type": "option"
        },
        "chain": {
          "char": "c",

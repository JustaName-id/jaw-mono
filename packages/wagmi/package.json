{
  "name": "@jaw.id/wagmi",
  "description": "Wagmi connector and React hooks for JAW.id.",
  "version": "0.1.12",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@jaw-mono/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./cjs-error.cjs",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JustaName-id/jaw-mono.git",
    "directory": "packages/wagmi"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "cjs-error.cjs",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@jaw.id/core": "0.2.6",
    "@wagmi/core": "^3.0.0",
    "tslib": "^2.3.0",
    "viem": "^2.38.2"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "react": ">=18.0.0",
    "wagmi": ">=3.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0"
  }
}

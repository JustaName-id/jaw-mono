{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": [
      "es2022"
    ],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": [
      "@jaw-mono/source"
    ],
    "baseUrl": ".",
    "paths": {
      "@jaw.id/core": [
        "packages/core/src/index.ts"
      ],
      "@jaw.id/core/*": [
        "packages/core/src/*"
      ],
      "@jaw.id/ui": [
        "packages/ui/src/index.ts"
      ],
      "@jaw/ui-native": [
        "packages/ui-native/src/index.ts"
      ],
      "@jaw/ui-native/*": [
        "packages/ui-native/src/*"
      ],
      "@jaw.id/ui/*": [
        "packages/ui/src/*"
      ],
      "@jaw/ui-native": [
        "packages/ui-native/src/index.ts"
      ],
      "@jaw/ui-native/*": [
        "packages/ui-native/src/*"
      ]
    }
  }
}

{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@jaw/ui-native": [
        "../../packages/ui-native/src/index.ts"
      ],
      "@jaw/ui-native/*": [
        "../../packages/ui-native/src/*"
      ],
      "@jaw.id/core": [
        "../../packages/core/src/index.ts"
      ],
      "@jaw.id/core/*": [
        "../../packages/core/src/*"
      ]
    },
    "baseUrl": "."
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    "../../packages/ui-native/src/**/*.ts",
    "../../packages/ui-native/src/**/*.tsx",
    "../../packages/core/src/**/*.ts"
  ]
}
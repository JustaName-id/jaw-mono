# JAW Demo Native Environment Variables
# Copy this file to .env and fill in your values

# API Key from JAW
EXPO_PUBLIC_API_KEY=your-api-key-here

# Default chain ID (1 = Ethereum Mainnet, 11155111 = Sepolia)
EXPO_PUBLIC_DEFAULT_CHAIN_ID=11155111

# Relying Party settings for Passkeys
# For production: use keys.jaw.id
# For local development: use ngrok URL (e.g., abc123.ngrok-free.app)
EXPO_PUBLIC_RP_ID=keys.jaw.id
EXPO_PUBLIC_RP_NAME=JAW Wallet
EXPO_PUBLIC_KEYS_URL=https://keys.jaw.id
